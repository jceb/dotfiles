use std/log
# use std/clip # once clipboard support lands in nushell

# Get git root
def find-git-root []: nothing -> string {
  let cmd = do -c {git rev-parse --show-toplevel} | complete
  if $cmd.exit_code == 0 {
    $cmd.stdout | lines | first
  } else {
    error make {msg: "git root not found"}
  }
}

# Get jj root
def find-jj-root []: nothing -> string {
  let cmd = do -c {jj workspace root} | complete
  if $cmd.exit_code == 0 {
    $cmd.stdout | lines | first
  } else {
    error make {msg: "jj root not found"}
  }
}

# Find repository root directory
def find-root []: string -> record<directory: string, scm: string> {
  let path = $in
  def find-dir []: string -> string {
    let p = $in
    if ($p | path type) == "dir" {
      return $p
    }
    $p | path dirname | find-dir
  }
  cd ($path | find-dir)
  mut root = ""
  mut scm = ""
  try {
    $root = find-jj-root
    $scm = "jj"
    log debug "found a jujutsu repository"
  } catch {
    log debug "not a jujutsu repository"
  }
  if ($root | is-empty) {
    try {
      $root = find-git-root
      $scm = "git"
      log debug "found a git repository"
    } catch {
      log debug "not a git repository"
    }
  }
  if ($root | is-empty) {
    error make {msg: "SCM root directory not found"}
  }
  { directory: $root, scm: $scm }
}

# Get current repository branch
def get-current-branch []: record<directory: string, scm: string> -> string {
  let ctx = $in
  match $ctx.scm {
    jj => (jj log --no-graph -r 'heads(::@ & bookmarks())' -T 'remote_bookmarks.filter(|b| b.remote() != "git").map(|b| b.name()).join("\n")' | lines | first),
    git => (git rev-parse --abbrev-ref HEAD | lines | first)
  }
}

# Get remote
def get-remote [
  name: string = ""
  # Remote name, defaults to the first found remote
]: record<directory: string, scm: string> -> record<name: string, url: string> {
  let ctx = $in
  let remotes = match $ctx.scm {
    jj => (jj git remote list | lines | parse "{name} {url}"),
    git => (git remote -v | parse "{name}\t{url} {_}")
  }
  let remote = if ($name | is-not-empty) {
    $remotes | where name == $name
  } else {
    $remotes
  } | first
  {
    name: $remote.name
    url: (if ($remote.url | str starts-with "git@") { $remote.url | str replace "ssh.dev.azure.com:v3" "dev.azure.com" | str replace ":" "/" | str replace "git@" "https://"} else { $remote.url })
  }
}

let CONFIG_PATH = "~/.config/huburl/config.toml" | path expand

def load-config []: nothing -> record<forges: record<github: list<string>, gitlab: list<string>, gitea: list<string>, forgejo: list<string>, azure: list<string>, srht: list<string>>> {
  let config_user = if ($CONFIG_PATH | path exists) { open $CONFIG_PATH } else { {} }
  let config_default = {
    forges: {
      github: ["github.com"]
      gitlab: ["gitlab.com"]
      gitea: ["gitea.com"]
      forgejo: ["codeberg.org"]
      azure: ["dev.azure.com"]
      srht: ["git.sr.ht"]
    }
  }
  $config_default | update forges (
    $config_default.forges |
      update github ($config_default.forges.github | append ($config_user | get -o forges.github.hostnames | default [])) |
      update gitlab ($config_default.forges.gitlab | append ($config_user | get -o forges.gitlab.hostnames | default [])) |
      update gitea ($config_default.forges.gitea | append ($config_user | get -o forges.gitea.hostnames | default [])) |
      update forgejo ($config_default.forges.forgejo | append ($config_user | get -o forges.forgejo.hostnames | default [])) |
      update azure ($config_default.forges.azure | append ($config_user | get -o forges.azure.hostnames | default [])) |
      update srht ($config_default.forges.srht | append ($config_user | get -o forges.srht.hostnames | default []))
  )
}

let FORGE_GITHUB = "GitHub"
let FORGE_GITLAB = "GitLab"
let FORGE_GITEA = "GitTea"
let FORGE_FORGEJO = "Forgejo"
let FORGE_AZURE = "Azure DevOps"
let FORGE_SRHT = "Source Hut"

# Join URL
def join-url [
  config: record<forges: record<github: list<string>, gitlab: list<string>, gitea: list<string>, forgejo: list<string>, azure: list<string>, srht: list<string>>>
  # Configuration
  remote: record<name: string, url: string>
  # Remote
  branch: string
  # Branch
  --path (-p): record<path: string, linenr: string>
  # Path to file or directory
]: record<directory: string, scm: string> -> string {
  let ctx = $in
  let url = $remote.url | url parse
  let forge_type = if ($url.host in $config.forges.github) {
    $FORGE_GITHUB
  } else if ($url.host in $config.forges.gitlab) {
    $FORGE_GITLAB
  } else if ($url.host in $config.forges.gitea) {
    $FORGE_GITEA
  } else if ($url.host in $config.forges.forgejo) {
    $FORGE_FORGEJO
  } else if ($url.host in $config.forges.azure) {
    $FORGE_AZURE
  } else if ($url.host in $config.forges.srht) {
    $FORGE_SRHT
  } else {
    log warning $"Unknown forge type, falling back to type ($FORGE_GITLAB)"
    log info $"Configure your custom forge in file ($CONFIG_PATH)\nSupported forge types: github, gitlab, gitea, forgjo, azure, srht\nSample configuration for this forge:\n\n[forges.gitlab]\nhostnames = [ \"($url.host)\" ]"
    $FORGE_GITLAB
  }
  log debug $"found a forge of type: ($forge_type)"
  mut segment = if $forge_type in [$FORGE_GITEA $FORGE_FORGEJO] { "src/branch" } else if $forge_type in [$FORGE_AZURE] { "" } else { "tree" }
  let segment_gitea = "src/branch"
  mut fragment = ""
  let params = if $forge_type in [$FORGE_AZURE] {
    [{key: version, value: $"GB($branch)" }] | if ($path | is-not-empty) {
      append [{key: path, value: $path.path}]
    } else { $in }
  } else if $forge_type in [$FORGE_SRHT] {
    [{key: "view-source", value: "" }]
  } else {
    []
  }
  let branch = if $forge_type in [$FORGE_AZURE] { "" } else { $branch }
  let path = if ($path | is-not-empty) {
    if $forge_type in [$FORGE_GITHUB $FORGE_GITLAB $FORGE_SRHT] {
      let type = [$ctx.directory $path.path] | path join | path type
      $segment = if $type != "dir" { if $forge_type in [$FORGE_SRHT] { "tree" } else { "blob" }} else { $segment }
      if ($path.linenr | is-not-empty) and $type != "dir" {
        $fragment = $"L($path.linenr)"
      }
      $path.path
    } else {
      ""
    }
  } else {""}
  let url = if $forge_type in [$FORGE_AZURE] {
    let p = $url.path | path split; $url | update path ($p | insert ($p | length | $in - 1) _git | path join)
  } else { $url }
  $url | reject query | update path ([($url.path | str replace -r ".git$" "") $segment $branch $path] | path join) | update params ($in.params | append $params) | update fragment $fragment | url join
}

# Builds the URL of the current repository and path in the source control hub
def main [
  path: path = ""
  # File or directory path, defaults to the root of the repository
  --open (-o)
  # Open URL in browser
  --copy (-c)
  # Copy URL into the clipboard
  --remote (-r): string
  # Specific remote name, defaults to the first remote
  --verbose (-v)
  # Verbose log output
]: nothing -> string {
  if $verbose {
    $env.NU_LOG_LEVEL = "debug"
  }
  let path = $path | parse --regex '^(?<path>[^:]+)(?::(?<linenr>[0-9]+))?$' | if ($in | is-not-empty) {first | update path ($in.path | path expand)} else {{path: (pwd | path expand), linenr: null}}
  let ctx = $path.path | find-root
  cd $ctx.directory
  log debug $"repository root directory: ($ctx.directory)"
  let branch = $ctx | get-current-branch
  log debug $"current branch: ($branch)"
  let remote = $ctx | get-remote $remote
  log debug $"current remote: ($remote)"
  let path = $path | update path ($in.path | path relative-to $ctx.directory)
  log debug $"relative path: ($path)"
  let config = load-config
  let url = $ctx | join-url $config $remote $branch --path $path
  log debug $"url: ($url)"
  if $open { xdg-open $url }
  if $copy { $url | xsel -i }
  # if $copy { $url | clip copy } # once clipboard support lands in nushell
  $url
}
