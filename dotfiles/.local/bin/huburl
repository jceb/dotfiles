use std/log
# use std/clip # once clipboard support lands in nushell

# Get git root
def find-git-root []: nothing -> string {
  let cmd = do -c {git rev-parse --show-toplevel} | complete
  if $cmd.exit_code == 0 {
    $cmd.stdout | lines | first
  } else {
    error make {msg: "git root not found"}
  }
}

# Get jj root
def find-jj-root []: nothing -> string {
  let cmd = do -c {jj workspace root} | complete
  if $cmd.exit_code == 0 {
    $cmd.stdout | lines | first
  } else {
    error make {msg: "jj root not found"}
  }
}

# Find repository root directory
def find-root []: string -> record<directory: string, scm: string> {
  let path = $in
  def find-dir []: string -> string {
    let p = $in
    if ($p | path type) == "dir" {
      return $p
    }
    $p | path dirname | find-dir
  }
  cd ($path | find-dir)
  mut root = ""
  mut scm = ""
  try {
    $root = find-jj-root
    $scm = "jj"
    log debug "found a jujutsu repository"
  } catch {
    log debug "not a jujutsu repository"
  }
  if ($root | is-empty) {
    try {
      $root = find-git-root
      $scm = "git"
      log debug "found a git repository"
    } catch {
      log debug "not a git repository"
    }
  }
  if ($root | is-empty) {
    error make {msg: "SCM root directory not found"}
  }
  { directory: $root, scm: $scm }
}

# Get current repository branch
def get-current-branch []: record<directory: string, scm: string> -> string {
  let ctx = $in
  match $ctx.scm {
    jj => (jj log --no-graph -r 'heads(::@ & bookmarks())' -T 'remote_bookmarks.filter(|b| b.remote() != "git").map(|b| b.name()).join("\n")' | lines | first),
    git => (git rev-parse --abbrev-ref HEAD | lines | first)
  }
}

# Transforms remote into a HTTPS URL
def transform-remote []: string -> string {
  let url = $in
  if ($url | str starts-with "git@") {
    $url | str replace "ssh.dev.azure.com:v3" "dev.azure.com" | str replace ":" "/" | str replace "git@" "https://"
  } else {
    $url
  }
}

# Get remote
def get-remote [
  name: string = ""
  # Remote name, defaults to the first found remote
]: record<directory: string, scm: string> -> record<name: string, url: string> {
  let ctx = $in
  let remotes = match $ctx.scm {
    jj => (jj git remote list | lines | parse "{name} {url}"),
    git => (git remote -v | parse "{name}\t{url} {_}")
  }
  let remote = if ($name | is-not-empty) {
    $remotes | where name == $name
  } else {
    $remotes
  } | first
  {
    name: $remote.name
    url: ($remote.url | transform-remote)
  }
}

let CONFIG_PATH = "~/.config/huburl/config.toml" | path expand
let CONFIG_DEFAULT = {
  hubs: {
    github: ["github.com"]
    gitlab: ["gitlab.com"]
    gitea: ["cloud.gitea.com"]
    forgejo: ["codeberg.org"]
    azure: ["dev.azure.com"]
    srht: ["git.sr.ht"]
  }
}

def load-config []: nothing -> record<hubs: record<github: list<string>, gitlab: list<string>, gitea: list<string>, forgejo: list<string>, azure: list<string>, srht: list<string>>> {
  let config_user = if ($CONFIG_PATH | path exists) { open $CONFIG_PATH } else { {} }
  $CONFIG_DEFAULT | update hubs (
    $CONFIG_DEFAULT.hubs |
      update github ($CONFIG_DEFAULT.hubs.github | append ($config_user | get -o hubs.github.hostnames | default [])) |
      update gitlab ($CONFIG_DEFAULT.hubs.gitlab | append ($config_user | get -o hubs.gitlab.hostnames | default [])) |
      update gitea ($CONFIG_DEFAULT.hubs.gitea | append ($config_user | get -o hubs.gitea.hostnames | default [])) |
      update forgejo ($CONFIG_DEFAULT.hubs.forgejo | append ($config_user | get -o hubs.forgejo.hostnames | default [])) |
      update azure ($CONFIG_DEFAULT.hubs.azure | append ($config_user | get -o hubs.azure.hostnames | default [])) |
      update srht ($CONFIG_DEFAULT.hubs.srht | append ($config_user | get -o hubs.srht.hostnames | default []))
  )
}

let HUB_GITHUB = "GitHub"
let HUB_GITLAB = "GitLab"
let HUB_GITEA = "GitTea"
let HUB_FORGEJO = "Forgejo"
let HUB_AZURE = "Azure DevOps"
let HUB_SRHT = "Source Hut"

# Join URL
def join-url [
  config: record<hubs: record<github: list<string>, gitlab: list<string>, gitea: list<string>, forgejo: list<string>, azure: list<string>, srht: list<string>>>
  # Configuration
  remote: record<name: string, url: string>
  # Remote
  branch: string
  # Branch
  --path (-p): record<path: string, linenr: string>
  # Path to file or directory
]: record<directory: string, scm: string> -> string {
  let ctx = $in
  let url = $remote.url | url parse
  let hub_type = if ($url.host in $config.hubs.github) {
    $HUB_GITHUB
  } else if ($url.host in $config.hubs.gitlab) {
    $HUB_GITLAB
  } else if ($url.host in $config.hubs.gitea) {
    $HUB_GITEA
  } else if ($url.host in $config.hubs.forgejo) {
    $HUB_FORGEJO
  } else if ($url.host in $config.hubs.azure) {
    $HUB_AZURE
  } else if ($url.host in $config.hubs.srht) {
    $HUB_SRHT
  } else {
    log warning $"Unknown hub type, falling back to type ($HUB_GITLAB)"
    log info $"Configure your custom hub in file ($CONFIG_PATH)\nSupported hub types: github, gitlab, gitea, forgjo, azure, srht\nSample configuration for this hub:\n\n[hubs.gitlab]\nhostnames = [ \"($url.host)\" ]"
    $HUB_GITLAB
  }
  log debug $"found a hub of type: ($hub_type)"
  mut segment = if $hub_type in [$HUB_GITEA $HUB_FORGEJO] { "src/branch" } else if $hub_type in [$HUB_AZURE] { "" } else { "tree" }
  let segment_gitea = "src/branch"
  mut fragment = ""
  let params = if $hub_type in [$HUB_AZURE] {
    [{key: version, value: $"GB($branch)" }] | if ($path | is-not-empty) and ($path.path | is-not-empty) {
      append [{key: path, value: $path.path}]
    } else { $in }
  } else if $hub_type in [$HUB_SRHT] {
    [{key: "view-source", value: "" }]
  } else {
    []
  }
  let branch = if $hub_type in [$HUB_AZURE] { "" } else { $branch }
  let path = if ($path | is-not-empty) {
    if $hub_type in [$HUB_GITHUB $HUB_GITLAB $HUB_GITEA $HUB_FORGEJO $HUB_SRHT] {
      let type = [$ctx.directory $path.path] | path join | path type
      $segment = if $type != "dir" { if $hub_type in [$HUB_SRHT] { "tree" } else { "blob" }} else { $segment }
      if ($path.linenr | is-not-empty) and $type != "dir" {
        $fragment = $"L($path.linenr)"
      }
      $path.path
    } else {
      ""
    }
  } else {""}
  let url = if $hub_type in [$HUB_AZURE] {
    let p = $url.path | path split; $url | update path ($p | if ($p | get ($p | length | $in - 2)) != "_git" {insert ($p | length | $in - 1) _git} else {$p} | path join)
  } else { $url }
  $url | reject query | reject username | reject password | update path ([($url.path | str replace -r ".git$" "") $segment $branch $path] | path join) | update params ($in.params | append $params) | update fragment $fragment | url join
}

def test-join-url [] {
  use std/assert
  let ctx = {directory: ".", scm: "git"}
  let config = $CONFIG_DEFAULT

  # GitHub
  let remote = {name: "origin", url: ("git@github.com:example/repo.git" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://github.com/example/repo/tree/main/"
  assert ($res == $exp) $"When a github repository is provided, then the result should be a gitea url. Result: ($res), Expected: ($exp)"

  let remote = {name: "origin", url: ("https://github.com/example/repo" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://github.com/example/repo/tree/main/"
  assert ($res == $exp) $"When a github repository is provided, then the result should be a github url. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: ""}
  let exp = "https://github.com/example/repo/blob/main/huburl"
  assert ($res == $exp) $"When a repository and path at github is provided, then the result should be a github url with a path. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: "23"}
  let exp = "https://github.com/example/repo/blob/main/huburl#L23"
  assert ($res == $exp) $"When a repository and path with line number at github is provided, then the result should be a github url with a path. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: ".", linenr: "23"}
  let exp = "https://github.com/example/repo/tree/main/."
  assert ($res == $exp) $"When a repository and directory path with line number at github is provided, then the result should be a github url with a path and without the line number. Result: ($res), Expected: ($exp)"

  # GitLab
  let remote = {name: "origin", url: ("git@gitlab.com:example/repo.git" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://gitlab.com/example/repo/tree/main/"
  assert ($res == $exp) $"When a gitlab repository is provided, then the result should be a gitea url. Result: ($res), Expected: ($exp)"

  let remote = {name: "origin", url: ("https://gitlab.com/example/repo" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://gitlab.com/example/repo/tree/main/"
  assert ($res == $exp) $"When a gitlab repository is provided, then the result should be a gitlab url. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: ""}
  let exp = "https://gitlab.com/example/repo/blob/main/huburl"
  assert ($res == $exp) $"When a repository and path at gitlab is provided, then the result should be a gitlab url with a path. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: "23"}
  let exp = "https://gitlab.com/example/repo/blob/main/huburl#L23"
  assert ($res == $exp) $"When a repository and path with line number at gitlab is provided, then the result should be a gitlab url with a path and a line number. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: ".", linenr: "23"}
  let exp = "https://gitlab.com/example/repo/tree/main/."
  assert ($res == $exp) $"When a repository and directory path with line number at gitlab is provided, then the result should be a gitlab url with a path and without the line number. Result: ($res), Expected: ($exp)"

  # Gitea
  # TODO: find a proper SSH URL
  let remote = {name: "origin", url: ("https://cloud.gitea.com/example/repo" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://cloud.gitea.com/example/repo/src/branch/main/"
  assert ($res == $exp) $"When a gitea repository is provided, then the result should be a gitea url. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: ""}
  let exp = "https://cloud.gitea.com/example/repo/blob/main/huburl"
  assert ($res == $exp) $"When a repository and path at gitea is provided, then the result should be a gitea url with a path. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: "23"}
  let exp = "https://cloud.gitea.com/example/repo/blob/main/huburl#L23"
  assert ($res == $exp) $"When a repository and path with line number at gitea is provided, then the result should be a gitea url with a path and a line number. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: ".", linenr: "23"}
  let exp = "https://cloud.gitea.com/example/repo/src/branch/main/."
  assert ($res == $exp) $"When a repository and directory path with line number at gitea is provided, then the result should be a gitea url with a path and without the line number. Result: ($res), Expected: ($exp)"

  # Forgejo
  # TODO: find a proper SSH URL

  let remote = {name: "origin", url: ("https://codeberg.org/example/repo" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://codeberg.org/example/repo/src/branch/main/"
  assert ($res == $exp) $"When a forgejo repository is provided, then the result should be a forgejo url. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: ""}
  let exp = "https://codeberg.org/example/repo/blob/main/huburl"
  assert ($res == $exp) $"When a repository and path at forgejo is provided, then the result should be a forgejo url with a path. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: "23"}
  let exp = "https://codeberg.org/example/repo/blob/main/huburl#L23"
  assert ($res == $exp) $"When a repository and path with line number at forgejo is provided, then the result should be a forgejo url with a path and a line number. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: ".", linenr: "23"}
  let exp = "https://codeberg.org/example/repo/src/branch/main/."
  assert ($res == $exp) $"When a repository and directory path with line number at forgejo is provided, then the result should be a forgejo url with a path and without the line number. Result: ($res), Expected: ($exp)"

  # Azure DevOps
  let remote = {name: "origin", url: ("git@ssh.dev.azure.com:v3/ORG/PROJECT/repo" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://dev.azure.com/ORG/PROJECT/_git/repo/?version=GBmain"
  assert ($res == $exp) $"When an azure repository is provided with a SSH remote, then the result should be a sr.ht url. Result: ($res), Expected: ($exp)"

  let remote = {name: "origin", url: ("https://user@dev.azure.com/ORG/PROJECT/_git/repo" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://dev.azure.com/ORG/PROJECT/_git/repo/?version=GBmain"
  assert ($res == $exp) $"When an azure repository is provided, then the result should be an azure url. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "", linenr: ""}
  let exp = "https://dev.azure.com/ORG/PROJECT/_git/repo/?version=GBmain"
  assert ($res == $exp) $"When a repository and no path at azure is provided, then the result should be an azure url without a path. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: ""}
  let exp = "https://dev.azure.com/ORG/PROJECT/_git/repo/?version=GBmain&path=huburl"
  assert ($res == $exp) $"When a repository and path at azure is provided, then the result should be an azure url with a path. Result: ($res), Expected: ($exp)"

  ## not supported
  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: "23"}
  let exp = "https://dev.azure.com/ORG/PROJECT/_git/repo/?version=GBmain&path=huburl"
  assert ($res == $exp) $"When a repository and path with line number at azure is provided, then the result should be an azure url with a path and without a line number - azure doesn't support it. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: ".", linenr: "23"}
  let exp = "https://dev.azure.com/ORG/PROJECT/_git/repo/?version=GBmain&path=."
  assert ($res == $exp) $"When a repository and directory path with line number at azure is provided, then the result should be an azure url with a path and without the line number. Result: ($res), Expected: ($exp)"

  # Source Hut
  let remote = {name: "origin", url: ("git@git.sr.ht:~example/repo" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://git.sr.ht/~example/repo/tree/main/?view-source="
  assert ($res == $exp) $"When a sr.ht repository is provided with a SSH remote, then the result should be a sr.ht url. Result: ($res), Expected: ($exp)"

  let remote = {name: "origin", url: ("https://git.sr.ht/~example/repo" | transform-remote)}
  let res = $ctx | join-url $config $remote "main"
  let exp = "https://git.sr.ht/~example/repo/tree/main/?view-source="
  assert ($res == $exp) $"When a sr.ht repository is provided, then the result should be a sr.ht url. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: ""}
  let exp = "https://git.sr.ht/~example/repo/tree/main/huburl?view-source="
  assert ($res == $exp) $"When a repository and path at sr.ht is provided, then the result should be a sr.ht url with a path. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: "huburl", linenr: "23"}
  let exp = "https://git.sr.ht/~example/repo/tree/main/huburl?view-source=#L23"
  assert ($res == $exp) $"When a repository and path with line number at sr.ht is provided, then the result should be a sr.ht url with a path and a line number. Result: ($res), Expected: ($exp)"

  let res = $ctx | join-url $config $remote "main" --path {path: ".", linenr: "23"}
  let exp = "https://git.sr.ht/~example/repo/tree/main/.?view-source="
  assert ($res == $exp) $"When a repository and directory path with line number at sr.ht is provided, then the result should be a sr.ht url with a path and without the line number. Result: ($res), Expected: ($exp)"
  log info "All tests passed"
}

# Builds the URL of the current repository and path in the source control hub
def main [
  path: path = ""
  # File or directory path, defaults to the root of the repository
  --open (-o)
  # Open URL in browser
  --copy (-c)
  # Copy URL into the clipboard
  --remote (-r): string
  # Specific remote name, defaults to the first remote
  --verbose (-v)
  # Verbose log output
  --test
  # Run tests
]: nothing -> string {
  if $test {
    test-join-url
    exit 0
  }
  if $verbose {
    $env.NU_LOG_LEVEL = "debug"
  }
  let path = $path | parse --regex '^(?<path>[^:]+)(?::(?<linenr>[0-9]+))?$' | if ($in | is-not-empty) {first | update path ($in.path | path expand)} else {{path: (pwd | path expand), linenr: null}}
  let ctx = $path.path | find-root
  cd $ctx.directory
  log debug $"repository root directory: ($ctx.directory)"
  let branch = $ctx | get-current-branch
  log debug $"current branch: ($branch)"
  let remote = $ctx | get-remote $remote
  log debug $"current remote: ($remote)"
  let path = $path | update path ($in.path | path relative-to $ctx.directory)
  log debug $"relative path: ($path)"
  let config = load-config
  let url = $ctx | join-url $config $remote $branch --path $path
  log debug $"url: ($url)"
  if $open { xdg-open $url }
  if $copy { $url | xsel -i }
  # if $copy { $url | clip copy } # once clipboard support lands in nushell
  $url
}
